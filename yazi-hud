  echo -e "\033[38;2;176;38;255m╭─ cowboy of cyberspace ─────────────────────────────╮\033[0m"
  echo -e "\033[38;2;$R;$G;$B;48;2;7;11;23m│  YAZI HUD ONLINE  //  faccao ativa  //  neon feed  │\033[0m"
  echo -e "\033[38;2;176;38;255m╰─────────────────────────────────────────────────────╯\033[0m"
  yazi
  sleep 0.3
done
